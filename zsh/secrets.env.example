# Copy this file to secrets.env, fill in your values, then encrypt it:
#   cp secrets.env.example secrets.env
#   age -p -o secrets.age secrets.env
#   rm secrets.env
#
# Each line should be: export VAR_NAME=value

export CI_JOB_TOKEN=
export CI_BUILD_TOKEN=
export DIVAR_CI_DEPLOY_TOKEN=
export OCEAN_ACCESS_TOKEN=
export CLAUDE_PROXY_IP=
export CLAUDE_PROXY_PORT=

